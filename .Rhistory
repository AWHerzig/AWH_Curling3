}
tryCatch(
{
matches <- grepl(search_input, choices, ignore.case = TRUE, perl = TRUE)
regexError("")  # Clear any previous errors
choices[matches]
},
error = function(e) {
regexError("Invalid regular expression. Please correct it.")  # Store error
return(choices)  # Return full list to avoid crashing
}
)
}
# Reactive trial options based on regex search
observe({
updateCheckboxGroupInput(session, "selected_trials",
choices = safeFilter(input$trial_search, trialOptions))
})
# Reactive report options based on regex search
observe({
updateCheckboxGroupInput(session, "selected_reports",
choices = safeFilter(input$report_search, reportOptions),
inline = TRUE)
})
# Display regex errors
output$searchError <- renderText({
regexError()
})
# Render UI for dynamic label inputs (aligned next to checkboxes)
output$trial_labels <- renderUI({
if (is.null(input$selected_trials) || length(input$selected_trials) == 0) {
return(NULL)
}
lapply(input$selected_trials, function(trial) {
textInput(inputId = paste0("label_", trial),
label = NULL,  # No label to keep it compact
value = trial,  # Default label
width = "100%")  # Makes sure text boxes are well aligned
})
})
# Create a data frame of selected trials with custom labels
output$trialsTable <- renderTable({
if (is.null(input$selected_trials) || length(input$selected_trials) == 0) {
return(data.frame(Trials = character(), Labels = character()))
}
data.frame(
Trials = input$selected_trials,
Labels = sapply(input$selected_trials, function(trial) {
input[[paste0("label_", trial)]]  # Retrieve user-provided label
}),
stringsAsFactors = FALSE
)
})
# Save selected data to global environment and display confirmation image
observeEvent(input$save_button, {
trials_data <- data.frame(
Trials = input$selected_trials,
Labels = sapply(input$selected_trials, function(trial) {
input[[paste0("label_", trial)]]
}),
stringsAsFactors = FALSE
)
reports_data <- input$selected_reports
# Assign to global environment
assign("chosenTrials", trials_data, envir = .GlobalEnv)
assign("chosenReports", reports_data, envir = .GlobalEnv)
# Display image confirmation
output$confirmationImage <- renderImage({
list(src = "/Users/leojo/OneDrive/Documents/GroupW/frosty.png",
contentType = "image/png",
alt = "Selection saved!")
}, deleteFile = FALSE)  # Ensure the image remains available
})
}
# Run the app
shinyApp(ui, server, options = list(launch.browser = T))
