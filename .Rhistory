df
df <- data.frame(
r = c(1, 2, 2, 3, 3, 3, 3),
s = c(1, 1, 2, 1, 4, 2, 3)
)
df
df <- data.frame(
r = c(1, 2, 2, 3, 3, 3, 3),
s = c(1, 1, 2, 1, 4, 2, 3),
w = 1:7
)
df
df <- data.frame(
r = c(1, 2, 2, 3, 3, 3, 3),
s = c(1, 1, 2, 1, 4, 2, 3),
w = 1:7
) %>% mutate(
st = 2^r-1
)
df
data.frame(
r = c(1, 2, 2, 3, 3, 3, 3),
s = c(1, 1, 2, 1, 4, 2, 3),
w = 1:7
) %>% mutate(
st = 2^r-1
)
data.frame(
r = c(1, 2, 2, 3, 3, 3, 3),
s = c(1, 1, 2, 1, 4, 2, 3),
w = 1:7
) %>% mutate(
st = (2^r-1) - (r-s)
)
data.frame(
r = c(1, 2, 2, 3, 3, 3, 3),
s = c(1, 1, 2, 1, 4, 2, 3),
w = c(1, 2, 3, 4, 7, 5, 6)
) %>% mutate(
st = (2^r-1) - (r-s)
)
data.frame(
r = c(1, 2, 2, 3, 3, 3, 3),
s = c(1, 1, 2, 1, 4, 2, 3),
w = c(1, 2, 3, 4, 7, 5, 6)
) %>% mutate(
st = (2^r-1) #- (r-s)
)
data.frame(
r = c(1, 2, 2, 3, 3, 3, 3),
s = c(1, 1, 2, 1, 4, 2, 3),
w = c(1, 2, 3, 4, 7, 5, 6)
) %>% mutate(
st = (2^(r-1)) #- (r-s)
)
data.frame(
r = c(1, 2, 2, 3, 3, 3, 3),
s = c(1, 1, 2, 1, 4, 2, 3),
w = c(1, 2, 3, 4, 7, 5, 6)
) %>% mutate(
st = (2^(r-1)) + (s-1) #- (r-s)
)
